source 'https://rubygems.org'

# Ruby 3.4+ / 4.0: stdlib pieces are separate gems; older Jekyll/Liquid still require them.
gem 'csv'
gem 'bigdecimal'

# Windows: no system zoneinfo; Jekyll needs TZInfo. Safe to include on all platforms (tiny gem).
gem 'tzinfo-data'

group :jekyll_plugins do
  gem 'jekyll'
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jemoji'
  gem 'webrick', '~> 1.8'
end

gem 'github-pages'
gem 'connection_pool', '2.5.0'
